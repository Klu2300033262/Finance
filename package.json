{
  "name": "spendwise-mern-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "install:all": "npm install && cd backend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "start": "cd backend && npm start",
    "start:prod": "npm run build && cd backend && npm start",
    "build:prod": "npm run build",
    "deploy:render": "cd backend && npm run deploy:render",
    "deploy:frontend": "npm run build && npm run deploy:vercel",
    "deploy:backend": "cd backend && npm run deploy:render",
    "deploy:full": "npm run build:prod && npm run deploy:frontend && npm run deploy:backend"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
